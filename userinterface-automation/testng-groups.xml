<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="UI Automation Test Suite" parallel="tests" thread-count="3" verbose="2">
    <parameter name="baseUrl" value="http://localhost:3000"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="base.AllureScreenshotListener"/>
        <listener class-name="listeners.TestExecutionListener"/>
    </listeners>

    <!-- Smoke Tests - Critical path tests -->
    <test name="Smoke Tests" parallel="methods" thread-count="2">
        <groups>
            <run>
                <include name="smoke"/>
                <exclude name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="tests.RegistrationFlowTest"/>
            <class name="tests.CookiesTest"/>
        </classes>
    </test>

    <!-- Registration Tests - All registration related tests -->
    <test name="Registration Tests" parallel="methods" thread-count="2">
        <groups>
            <run>
                <include name="registration"/>
                <include name="smoke"/>
                <include name="critical"/>
                <exclude name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="tests.RegistrationFlowTest"/>
        </classes>
    </test>

    <!-- Cookie Tests - All cookie related tests -->
    <test name="Cookie Tests" parallel="methods" thread-count="1">
        <groups>
            <run>
                <include name="cookies"/>
            </run>
        </groups>
        <classes>
            <class name="tests.CookiesTest"/>
        </classes>
    </test>

    <!-- Regression Tests - Full regression suite -->
    <test name="Regression Tests" parallel="classes" thread-count="2">
        <groups>
            <run>
                <include name="regression"/>
                <exclude name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="tests.RegistrationFlowTest"/>
            <class name="tests.CookiesTest"/>
        </classes>
    </test>

    <!-- UI Tests - All UI related tests -->
    <test name="UI Tests" parallel="methods" thread-count="2">
        <groups>
            <run>
                <include name="ui"/>
            </run>
        </groups>
        <classes>
            <class name="tests.CookiesTest"/>
            <class name="tests.RegistrationFlowTest"/>
        </classes>
    </test>

    <!-- Performance Tests - Performance related tests -->
    <test name="Performance Tests" parallel="methods" thread-count="1">
        <groups>
            <run>
                <include name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="tests.RegistrationFlowTest"/>
        </classes>
    </test>
</suite>
