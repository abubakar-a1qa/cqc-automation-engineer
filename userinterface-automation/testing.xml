<?xml version="1.0" encoding="UTF-8"?>
<suite name="UI Automation Test Suite" parallel="tests" thread-count="3" verbose="2">
    <parameter name="baseUrl" value="http://localhost:3000"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="base.AllureScreenshotListener"/>
        <listener class-name="listeners.TestExecutionListener"/>
    </listeners>

    <test name="Cookies Tests">
        <classes>
            <class name="tests.CookiesTest"/>
        </classes>
    </test>

    <test name="TestNG Test">
        <classes>
            <class name="tests.TestNGReportGenerationTest"/>
        </classes>
    </test>

    <test name="Help Form Tests">
        <classes>
            <class name="tests.HelpFormTest"/>
        </classes>
    </test>

    <test name="Timer Tests">
        <classes>
            <class name="tests.TimerTest"/>
        </classes>
    </test>

    <test name="Registration Flow Tests">
        <groups>
            <run>
                <include name="registration"/>
                <include name="smoke"/>
                <include name="critical"/>
                <include name="regression"/>
                <include name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="tests.RegistrationFlowTest"/>
        </classes>
    </test>
</suite>
